---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';

const capabilities = [
  { title: 'Shopping campaigns', description: 'Product feeds turned into shoppable Pins for retail and ecommerce brands.' },
  { title: 'High-intent discovery', description: 'Reach people actively planning purchases, not just browsing.' },
  { title: 'Long content lifespan', description: 'Pins keep driving traffic well beyond the campaign flight, unlike most social ad formats.' },
  { title: 'Visual-first creative', description: 'Creative built for Pinterest’s format, not repurposed from other platforms.' },
];
---

<BaseLayout
  title="Pinterest Ads Management"
  description="Pinterest advertising management for retail and lifestyle brands, built around shopping campaigns and high-intent discovery."
>
  <PageHero
    eyebrow="Paid Social / Pinterest"
    title="High-intent discovery advertising"
    description="Pinterest reaches people in planning mode. For retail and lifestyle brands, that makes it one of the highest-intent paid social channels available."
  />

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-8 sm:grid-cols-2">
      {capabilities.map((item) => (
        <div class="rounded-2xl border border-gray-100 p-6">
          <h3 class="font-semibold text-brand-slate">{item.title}</h3>
          <p class="mt-2 text-sm text-brand-slate-light">{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
