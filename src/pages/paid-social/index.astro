---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Icon from '../../components/Icon.astro';
import PlatformLogo from '../../components/PlatformLogo.astro';
import { cornerSocial } from '../../components/IconCluster.astro';

const platforms = [
  { title: 'Meta (Facebook & Instagram)', href: '/paid-social/meta', description: 'Facebook and Instagram campaigns built on creative testing and clean event tracking.', platform: 'facebook', color: 'green' },
  { title: 'Other Platforms', href: '/paid-social/other-platforms', description: 'LinkedIn and Pinterest, plus other channels, evaluated on merit for your audience.', icon: 'compass', color: 'orange' },
] as const;

const borderColors = {
  green: 'border-brand-green',
  orange: 'border-brand-orange',
} as const;

const badgeColors = {
  green: 'bg-brand-green/10 text-brand-green-dark',
  orange: 'bg-brand-orange/10 text-brand-orange-dark',
} as const;
---

<BaseLayout
  title="Paid Social"
  description="Paid social management across Meta, LinkedIn, Pinterest and other platforms, built on creative testing and clean conversion tracking."
>
  <PageHero
    eyebrow="Paid Social"
    title="Paid Social Management: Creative-Led Campaigns That Convert"
    description="Paid social succeeds or fails on creative and tracking. We manage both, testing systematically and making sure the data behind every decision is accurate."
    cluster={cornerSocial}
    anchorLogo="facebook"
  />

  <section class="bg-brand-slate">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="grid gap-8 sm:grid-cols-2">
        {platforms.map((platform) => (
          <a
            href={platform.href}
            class={`group block rounded-2xl border-2 bg-white p-8 transition hover:-translate-y-1 hover:shadow-lg ${borderColors[platform.color]}`}
          >
            {'platform' in platform ? (
              <PlatformLogo platform={platform.platform} class="h-8 w-auto" />
            ) : (
              <div class={`flex h-12 w-12 items-center justify-center rounded-xl ${badgeColors[platform.color]}`}>
                <Icon name={platform.icon} class="h-6 w-6" />
              </div>
            )}
            <h3 class="mt-4 text-lg font-semibold text-brand-slate">{platform.title}</h3>
            <p class="mt-2 text-sm text-brand-slate-light">{platform.description}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-green-dark opacity-0 transition group-hover:opacity-100">
              Learn more →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
