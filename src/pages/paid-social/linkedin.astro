---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';

const capabilities = [
  { title: 'Lead gen forms', description: 'Native forms that reduce friction for B2B leads without leaving the platform.' },
  { title: 'Account-based marketing', description: 'Target named accounts and decision-maker job titles directly.' },
  { title: 'Thought Leader Ads', description: 'Boost organic posts from your team’s personal profiles for authentic reach.' },
  { title: 'Predictive audiences', description: 'Let LinkedIn’s modelling extend your best-performing audiences at scale.' },
];
---

<BaseLayout
  title="LinkedIn Ads Management"
  description="LinkedIn advertising management for B2B lead generation, account-based marketing and thought leadership campaigns."
>
  <PageHero
    eyebrow="Paid Social / LinkedIn"
    title="B2B advertising that reaches the right job titles"
    description="LinkedIn is expensive if it's mismanaged. We build campaigns around precise targeting and lead quality, not just volume."
  />

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-8 sm:grid-cols-2">
      {capabilities.map((item) => (
        <div class="rounded-2xl border border-gray-100 p-6">
          <h3 class="font-semibold text-brand-slate">{item.title}</h3>
          <p class="mt-2 text-sm text-brand-slate-light">{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
