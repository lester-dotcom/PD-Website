---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Icon from '../../components/Icon.astro';
import PlatformLogo from '../../components/PlatformLogo.astro';
import { cornerSocial } from '../../components/IconCluster.astro';

const platforms = [
  {
    title: 'LinkedIn',
    description: 'The default choice for B2B lead generation and account-based targeting. We use native lead gen forms to cut friction, and target by job title, seniority and named account lists rather than broad industry categories.',
    platform: 'linkedin',
    color: 'green',
  },
  {
    title: 'Pinterest',
    description: 'High-intent discovery advertising, particularly strong for retail and lifestyle brands. Shopping campaigns built from your product feed reach people who are actively planning a purchase, and Pins keep driving traffic well beyond the campaign flight.',
    platform: 'pinterest',
    color: 'orange',
  },
] as const;

const borderColors = {
  green: 'border-brand-green',
  orange: 'border-brand-orange',
} as const;
---

<BaseLayout
  title="Other Paid Social Platforms"
  description="Paid social management on LinkedIn and Pinterest, plus other emerging platforms, evaluated on merit for your audience."
>
  <PageHero
    eyebrow="Paid Social / Other Platforms"
    title="LinkedIn & Pinterest Advertising: Beyond Facebook and Instagram"
    description="Not every audience lives on Meta. Where LinkedIn, Pinterest or another platform genuinely fits your audience, we'll say so, and manage it properly."
    cluster={cornerSocial}
    anchorLogo="linkedin"
  />

  <section class="bg-brand-slate">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="grid gap-6 sm:grid-cols-2">
        {platforms.map((item) => (
          <div class={`rounded-2xl border-2 bg-white p-8 ${borderColors[item.color]}`}>
            <PlatformLogo platform={item.platform} class="h-8 w-auto" />
            <h2 class="mt-4 text-xl font-semibold text-brand-slate">{item.title}</h2>
            <p class="mt-3 text-sm text-brand-slate-light">{item.description}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 border-t border-white/10 pt-10 text-white/60">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/10 text-brand-green">
          <Icon name="compass" class="h-6 w-6" />
        </div>
        <h2 class="mt-4 text-xl font-semibold text-white">Weighing up a newer platform?</h2>
        <p class="mt-3 max-w-2xl text-sm">
          TikTok, Snapchat, Reddit and others come up regularly in planning conversations. We'll assess any of them
          against your audience and budget honestly, recommending a test only where the fit is genuine, not because
          it's the newest option on the table.
        </p>
      </div>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
