---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import BlockRenderer from '../../components/BlockRenderer.astro';
import { cornerSocial } from '../../components/IconCluster.astro';

const page = await getEntry('pages', 'paid-social-meta');
if (!page) throw new Error('Missing pages/paid-social-meta.yaml content entry');
if (page.data.hidden) {
  if (page.data.redirectTo) return Astro.redirect(page.data.redirectTo, 301);
  return Astro.rewrite('/404');
}
const { title, metaDescription, hero, blocks } = page.data;
---

<BaseLayout title={title} description={metaDescription}>
  <PageHero
    eyebrow={hero.eyebrow}
    title={hero.title}
    description={hero.description}
    heroImage={hero.heroImage}
    heroImageAlt={hero.heroImageAlt}
    platform="facebook"
    cluster={cornerSocial}
    anchorLogo="facebook"
  />

  <BlockRenderer blocks={blocks} />
</BaseLayout>
