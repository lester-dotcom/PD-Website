---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import IconBadge from '../../components/IconBadge.astro';

const sharedCapabilities = [
  { title: 'Creative testing', description: 'Structured testing across formats and hooks so we know what’s actually driving performance.', icon: 'target', color: 'green' },
  { title: 'Pixel & Conversions API', description: 'Server-side tracking set up correctly for accurate data in an increasingly privacy-restricted world.', icon: 'shield', color: 'orange' },
  { title: 'Advantage+ campaigns', description: 'Evaluated on real results, not adopted just because Meta recommends it.', icon: 'sparkles', color: 'green' },
] as const;
---

<BaseLayout
  title="Meta Ads Management"
  description="Facebook and Instagram advertising management built on creative testing and accurate Pixel and Conversions API tracking."
>
  <PageHero
    eyebrow="Paid Social / Meta"
    title="Facebook & Instagram advertising, managed properly"
    description="We manage Meta accounts with a focus on the two things that actually move performance: creative testing and clean conversion tracking, across both Facebook and Instagram."
  />

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-8 sm:grid-cols-2">
      <div class="rounded-2xl border border-gray-100 p-8">
        <IconBadge icon="chat" color="green" />
        <h2 class="mt-4 text-lg font-semibold text-brand-slate">Facebook</h2>
        <p class="mt-3 text-sm text-brand-slate-light">
          Still one of the most efficient prospecting and remarketing channels available, particularly for
          considered purchases. We build feed, Reels and Marketplace placements around your funnel stage rather
          than running one generic ad set everywhere.
        </p>
      </div>
      <div class="rounded-2xl border border-gray-100 p-8">
        <IconBadge icon="sparkles" color="orange" />
        <h2 class="mt-4 text-lg font-semibold text-brand-slate">Instagram</h2>
        <p class="mt-3 text-sm text-brand-slate-light">
          A visual-first platform that rewards strong creative more than any other Meta placement. We prioritise
          Reels and Stories formats built natively for the platform, not repurposed static ads.
        </p>
      </div>
    </div>

    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      {sharedCapabilities.map((item) => (
        <div class="rounded-2xl border border-gray-100 p-6">
          <IconBadge icon={item.icon} color={item.color} />
          <h3 class="mt-4 font-semibold text-brand-slate">{item.title}</h3>
          <p class="mt-2 text-sm text-brand-slate-light">{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
