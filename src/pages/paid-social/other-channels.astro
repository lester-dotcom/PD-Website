---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';

const channels = [
  { title: 'TikTok', description: 'Short-form video advertising for brands with a genuinely younger or trend-led audience.' },
  { title: 'Snapchat', description: 'Reach for demographics that skew away from other major platforms.' },
  { title: 'Reddit', description: 'Niche community targeting for brands with a strong point of view.' },
  { title: 'Emerging platforms', description: 'We test new ad platforms on their merits before recommending budget.' },
];
---

<BaseLayout
  title="Other Paid Social Channels"
  description="Paid social management on TikTok, Snapchat, Reddit and other emerging platforms, evaluated on merit for your audience."
>
  <PageHero
    eyebrow="Paid Social / Other Channels"
    title="Beyond the big three"
    description="Not every audience lives on Meta, LinkedIn or Pinterest. We evaluate other platforms honestly — recommending them only where the audience and format genuinely fit."
  />

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-8 sm:grid-cols-2">
      {channels.map((item) => (
        <div class="rounded-2xl border border-gray-100 p-6">
          <h3 class="font-semibold text-brand-slate">{item.title}</h3>
          <p class="mt-2 text-sm text-brand-slate-light">{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
