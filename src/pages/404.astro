---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="This page could not be found." noindex>
  <section class="mx-auto flex max-w-2xl flex-col items-center px-6 py-24 text-center">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand-green-dark">404</p>
    <h1 class="mt-3 text-3xl font-bold text-brand-slate sm:text-4xl">Page not found</h1>
    <p class="mt-4 text-brand-slate-light">
      The page you're looking for doesn't exist, or isn't available right now.
    </p>
    <a
      href="/"
      class="mt-8 inline-block rounded-full bg-brand-green px-7 py-3 text-sm font-semibold text-brand-slate transition hover:bg-brand-green-dark"
    >
      Back to Homepage
    </a>
  </section>
</BaseLayout>
