---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import BlockRenderer from '../components/BlockRenderer.astro';

const page = await getEntry('pages', 'about-us');
if (!page) throw new Error('Missing pages/about-us.yaml content entry');
if (page.data.hidden) return Astro.rewrite('/404');
const { title, metaDescription, hero, blocks } = page.data;
---

<BaseLayout title={title} description={metaDescription}>
  <PageHero eyebrow={hero.eyebrow} title={hero.title} description={hero.description} />

  <BlockRenderer blocks={blocks} />
</BaseLayout>
