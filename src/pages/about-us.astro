---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBanner from '../components/CtaBanner.astro';
import ameliaPhoto from '../assets/team/amelia.jpg';
import lesterPhoto from '../assets/team/lester.jpg';

const team = [
  {
    name: 'Amelia Pratt',
    role: 'Co-Founder & Director',
    photo: ameliaPhoto,
    bio: "With deep-rooted paid search and marketing experience stretching back to the early days of search, Amelia has been digitally evolving right alongside the platforms she manages. Before founding Pratt Digital in 2013, she worked with some of London's top search agencies, including i-Level and Leapfrogg. Her strategic approach is built fresh for every account, blending creativity with a relentless focus on the data.",
  },
  {
    name: 'Lester Pratt',
    role: 'Co-Founder & Director',
    photo: lesterPhoto,
    bio: 'Twenty years in senior retail management gave Lester an analytical streak and a head for numbers most agency owners would envy. Since joining Pratt Digital, he has put his creative side to work across a wide range of successful campaigns, and genuinely enjoys the challenge of writing ad copy that actually earns the click.',
  },
];

const steps = [
  {
    title: 'Free audit',
    description: 'We dig into your account, competitors and market. You get a written breakdown you can keep, no obligation.',
  },
  {
    title: 'Build & launch',
    description: 'Structure, keywords, creative and tracking, done properly. Most accounts are live within two weeks.',
  },
  {
    title: 'Optimise & scale',
    description: 'Weekly bid, creative and landing-page tests. Monthly strategy calls in plain English. Scale what wins.',
  },
];
---

<BaseLayout
  title="About Us"
  description="Pratt Digital is an independent paid search and paid social agency. Learn who we are, how we work, and why clients stay with us for the long term."
>
  <PageHero
    eyebrow="About Us"
    title="About Pratt Digital: A Specialist Team, Not an Account Factory"
    description="Pratt Digital was built on a simple idea: PPC works best when it's managed by people who specialise in it, and who stay on your account long enough to actually understand your business."
  />

  <section class="mx-auto max-w-3xl px-6 py-16">
    <div class="prose-content space-y-6 text-brand-slate-light">
      <p>
        We're an independent paid media agency working across Google Ads, Microsoft Ads, Meta, LinkedIn and
        Pinterest. No junior account managers cutting their teeth on your budget, no template strategies copied
        from client to client. Every account gets a specialist who understands the platform and the numbers
        behind it.
      </p>
      <p>
        We work with brands who manage their paid media in-house and want an expert partner, and with agencies
        who need reliable white-label PPC delivery without building the capability internally.
      </p>
    </div>
  </section>

  <section class="bg-brand-slate">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)] lg:items-end">
        <div>
          <div class="flex items-center gap-3">
            <span class="h-px w-8 bg-brand-green"></span>
            <p class="text-sm font-semibold uppercase tracking-wide text-white/60">How we work</p>
          </div>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">
            Not like most other <span class="font-light italic text-brand-green">paid media agencies.</span>
          </h2>
        </div>
        <p class="text-white/60">
          Working with brands and agencies across the UK. No lock-ins: we earn the right to keep managing your
          account every month.
        </p>
      </div>

      <div class="mt-14 grid gap-10 sm:grid-cols-3 sm:divide-x sm:divide-white/10">
        {steps.map((step, i) => (
          <div class="sm:px-8 sm:first:pl-0">
            <p class="text-4xl font-bold text-brand-green">0{i + 1}</p>
            <h3 class="mt-4 font-semibold text-white">{step.title}</h3>
            <p class="mt-2 text-sm text-white/60">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-gray-100 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="flex items-center gap-3">
        <span class="h-px w-8 bg-brand-green"></span>
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-slate-light">The Directors</p>
      </div>
      <h2 class="mt-3 text-3xl font-bold text-brand-slate sm:text-4xl">
        Founded in 2013, <span class="font-light italic">still hands-on today.</span>
      </h2>

      <div class="mt-12 grid gap-12 sm:grid-cols-2">
        {team.map((person) => (
          <div class="flex gap-5">
            <Image
              src={person.photo}
              alt={`${person.name}, ${person.role} at Pratt Digital`}
              width={128}
              height={128}
              loading="lazy"
              decoding="async"
              class="h-32 w-32 shrink-0 rounded-full object-cover"
            />
            <div>
              <h3 class="font-semibold text-brand-slate">{person.name}</h3>
              <p class="text-sm font-medium text-brand-green-dark">{person.role}</p>
              <p class="mt-3 text-sm text-brand-slate-light">{person.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner title="Want to know more?" description="Get in touch and we'll walk you through how we work." />
</BaseLayout>
