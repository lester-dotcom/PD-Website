---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBanner from '../components/CtaBanner.astro';
---

<BaseLayout
  title="About Us"
  description="Pratt Digital is an independent paid search and paid social agency. Learn who we are, how we work, and why clients stay with us for the long term."
>
  <PageHero
    eyebrow="About Us"
    title="A specialist team, not an account factory"
    description="Pratt Digital was built on a simple idea: PPC works best when it's managed by people who specialise in it, and who stay on your account long enough to actually understand your business."
  />

  <section class="mx-auto max-w-3xl px-6 py-16">
    <div class="prose-content space-y-6 text-brand-slate-light">
      <p>
        We're an independent paid media agency working across Google Ads, Microsoft Ads, Meta, LinkedIn and
        Pinterest. No junior account managers cutting their teeth on your budget, no template strategies copied
        from client to client — every account gets a specialist who understands the platform and the numbers
        behind it.
      </p>
      <p>
        We work with brands who manage their paid media in-house and want an expert partner, and with agencies
        who need reliable white-label PPC delivery without building the capability internally.
      </p>
      <h2 class="text-xl font-semibold text-brand-slate">How we work</h2>
      <p>
        Every engagement starts with an audit — no assumptions, no recycled playbook. From there we build a plan
        tied to your actual commercial goals, not vanity metrics, and report on it in plain English every month.
      </p>
    </div>
  </section>

  <CtaBanner title="Want to know more?" description="Get in touch and we'll walk you through how we work." />
</BaseLayout>
