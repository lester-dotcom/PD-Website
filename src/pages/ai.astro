---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import BlockRenderer from '../components/BlockRenderer.astro';
import { cornerGeneral } from '../components/IconCluster.astro';

const page = await getEntry('pages', 'ai');
if (!page) throw new Error('Missing pages/ai.yaml content entry');
if (page.data.hidden) {
  if (page.data.redirectTo) return Astro.redirect(page.data.redirectTo, 301);
  return Astro.rewrite('/404');
}
const { title, metaDescription, hero, blocks } = page.data;
---

<BaseLayout title={title} description={metaDescription}>
  <PageHero
    eyebrow={hero.eyebrow}
    title={hero.title}
    description={hero.description}
    cluster={cornerGeneral}
  />

  <BlockRenderer blocks={blocks} />
</BaseLayout>
