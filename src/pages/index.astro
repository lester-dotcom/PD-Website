---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Icon from '../components/Icon.astro';
import IconBadge from '../components/IconBadge.astro';

const services = [
  {
    title: 'Paid Search',
    href: '/paid-search',
    description: 'Google Ads and Microsoft Ads accounts built and managed for efficient, scalable growth.',
    icon: 'search',
    color: 'green',
  },
  {
    title: 'Paid Social',
    href: '/paid-social',
    description: 'Meta, LinkedIn, Pinterest and beyond: creative-led social campaigns that convert.',
    icon: 'share',
    color: 'orange',
  },
  {
    title: 'For Agencies',
    href: '/for-agencies',
    description: 'White-label PPC delivery for agencies who want expert management without building an in-house team.',
    icon: 'briefcase',
    color: 'green',
  },
  {
    title: 'Training & Workshops',
    href: '/training-and-workshops',
    description: 'Hands-on PPC training for marketing teams who want to run campaigns in-house with confidence.',
    icon: 'graduation-cap',
    color: 'orange',
  },
  {
    title: 'AI',
    href: '/ai',
    description: 'How we use AI tools day to day, and how we approach emerging AI-native ad platforms like OpenAI Ads.',
    icon: 'sparkles',
    color: 'green',
  },
] as const;

const channels = [
  { title: 'Google Ads', description: 'Search, Shopping, Performance Max and YouTube', icon: 'search' },
  { title: 'Microsoft Ads', description: 'Incremental reach, often at a lower cost per click', icon: 'compass' },
  { title: 'Meta', description: 'Facebook and Instagram audiences at scale', icon: 'share' },
  { title: 'LinkedIn', description: 'B2B by job title, seniority and named accounts', icon: 'briefcase' },
  { title: 'Pinterest', description: 'High-intent shopping and discovery', icon: 'pin' },
  { title: 'AI-native platforms', description: 'OpenAI Ads and emerging channels, tested on merit', icon: 'sparkles' },
] as const;

const pillars = [
  {
    title: 'Specialists, not generalists',
    description: 'Every account is managed by someone who lives in paid media daily, not spread across ten disciplines.',
    icon: 'target',
    color: 'green',
  },
  {
    title: 'Data over guesswork',
    description: 'Decisions are backed by conversion data, not platform recommendations taken at face value.',
    icon: 'chart',
    color: 'orange',
  },
  {
    title: 'Straight-talking reporting',
    description: 'Clear monthly reporting that explains what happened, why, and what we are doing next.',
    icon: 'shield',
    color: 'green',
  },
] as const;

const cardColors = {
  green: 'bg-brand-green',
  orange: 'bg-brand-orange',
} as const;
---

<BaseLayout
  title="Paid Search & Paid Social Specialists"
  description="Pratt Digital is a paid search and paid social agency helping brands and agencies grow with data-led PPC management across Google, Microsoft, Meta, LinkedIn and Pinterest."
>
  <section class="relative overflow-hidden">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-6 py-20 sm:py-28 lg:grid-cols-2">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-green-dark">Pratt Digital</p>
        <h1 class="mt-3 text-4xl font-bold text-brand-slate sm:text-5xl">
          PPC management that's actually <span class="font-light italic">managed</span>.
        </h1>
        <p class="mt-5 text-lg text-brand-slate-light">
          We plan, build, and optimise paid search and paid social campaigns for brands and agencies who want a
          specialist on their account, not a junior working from a template.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/contact-us"
            class="rounded-full bg-brand-green px-7 py-3 text-sm font-semibold text-brand-slate transition hover:bg-brand-green-dark"
          >
            Get in Touch
          </a>
          <a
            href="/paid-search"
            class="rounded-full border border-brand-slate/20 px-7 py-3 text-sm font-semibold text-brand-slate transition hover:border-brand-slate/40"
          >
            Explore Our Services
          </a>
        </div>
      </div>

      <div class="relative hidden h-80 lg:block" aria-hidden="true">
        <svg viewBox="0 0 400 320" class="h-full w-full">
          <circle cx="330" cy="60" r="70" fill="var(--color-brand-green)" opacity="0.12" />
          <circle cx="70" cy="260" r="90" fill="var(--color-brand-orange)" opacity="0.12" />
          <g stroke="var(--color-brand-slate)" stroke-width="1.5" opacity="0.25">
            <circle cx="200" cy="160" r="4" fill="var(--color-brand-slate)" />
            <circle cx="240" cy="120" r="4" fill="var(--color-brand-slate)" />
            <circle cx="280" cy="150" r="4" fill="var(--color-brand-slate)" />
            <circle cx="150" cy="110" r="4" fill="var(--color-brand-slate)" />
            <line x1="200" y1="160" x2="240" y2="120" />
            <line x1="240" y1="120" x2="280" y2="150" />
            <line x1="200" y1="160" x2="150" y2="110" />
          </g>
          <polyline
            points="60,240 130,200 190,220 250,140 340,90"
            fill="none"
            stroke="var(--color-brand-green-dark)"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <circle cx="340" cy="90" r="6" fill="var(--color-brand-orange)" />
        </svg>
      </div>
    </div>
  </section>

  <section class="bg-brand-ink">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="flex items-center gap-3">
        <span class="h-px w-8 bg-brand-green"></span>
        <p class="text-sm font-semibold uppercase tracking-wide text-white/60">What we do</p>
      </div>
      <h2 class="mt-3 max-w-xl text-3xl font-bold text-white sm:text-4xl">
        One team, <span class="font-light italic text-brand-green">every channel that matters.</span>
      </h2>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <a
            href={service.href}
            class={`group block rounded-2xl p-6 transition hover:-translate-y-1 hover:shadow-xl ${cardColors[service.color]}`}
          >
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/25 text-brand-ink">
              <Icon name={service.icon} class="h-6 w-6" />
            </div>
            <h3 class="mt-4 font-semibold text-brand-ink">{service.title}</h3>
            <p class="mt-2 text-sm text-brand-ink/75">{service.description}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-ink opacity-0 transition group-hover:opacity-100">
              Learn more →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto grid max-w-6xl gap-12 px-6 py-20 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)] lg:items-start">
      <div>
        <div class="flex items-center gap-3">
          <span class="h-px w-8 bg-brand-orange"></span>
          <p class="text-sm font-semibold uppercase tracking-wide text-brand-slate-light">Channels</p>
        </div>
        <h2 class="mt-3 text-3xl font-bold text-brand-slate sm:text-4xl">
          Every major ad platform, <span class="font-light italic">one team.</span>
        </h2>
        <p class="mt-5 text-brand-slate-light">
          Certified across Google and Microsoft, with hands-on experience running Meta, LinkedIn and Pinterest
          day to day. We pick the mix that fits your customer, not our commission.
        </p>
      </div>

      <div class="grid divide-y divide-gray-100 overflow-hidden rounded-2xl border border-gray-100 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
        {channels.map((channel) => (
          <div class="flex gap-3 p-6">
            <Icon name={channel.icon} class="mt-0.5 h-5 w-5 shrink-0 text-brand-green-dark" />
            <div>
              <h3 class="font-semibold text-brand-slate">{channel.title}</h3>
              <p class="mt-1 text-sm text-brand-slate-light">{channel.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-gray-100 bg-gray-50">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <h2 class="text-2xl font-bold text-brand-slate sm:text-3xl">Why Pratt Digital</h2>
      <div class="mt-10 grid gap-10 sm:grid-cols-3">
        {pillars.map((pillar) => (
          <div>
            <IconBadge icon={pillar.icon} color={pillar.color} />
            <h3 class="mt-4 font-semibold text-brand-slate">{pillar.title}</h3>
            <p class="mt-2 text-sm text-brand-slate-light">{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
