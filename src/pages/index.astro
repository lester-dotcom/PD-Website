---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import IconCluster from '../components/IconCluster.astro';
import BlockRenderer from '../components/BlockRenderer.astro';

const page = await getEntry('pages', 'homepage');
if (!page) throw new Error('Missing pages/homepage.yaml content entry');
const { title, metaDescription, hero, blocks } = page.data;

const heroTitleParts = hero.title.split(/\*(.+?)\*/).map((part, i) => ({ text: part, italic: i % 2 === 1 }));
---

<BaseLayout title={title} description={metaDescription}>
  <section class="relative overflow-hidden">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-6 py-20 sm:py-28 lg:grid-cols-2">
      <div class="max-w-2xl">
        {hero.eyebrow && <p class="text-sm font-semibold uppercase tracking-wide text-brand-green-dark">{hero.eyebrow}</p>}
        <h1 class="mt-3 text-4xl font-bold text-brand-slate sm:text-5xl">
          {heroTitleParts.map((p) => (p.italic ? <span class="font-light italic">{p.text}</span> : p.text))}
        </h1>
        <p class="mt-5 text-lg text-brand-slate-light">{hero.description}</p>
        <div class="mt-8 flex flex-wrap gap-4">
          {hero.primaryButton && (
            <a
              href={hero.primaryButton.href}
              class="rounded-full bg-brand-green px-7 py-3 text-sm font-semibold text-brand-slate transition hover:bg-brand-green-dark"
            >
              {hero.primaryButton.text}
            </a>
          )}
          {hero.secondaryButton && (
            <a
              href={hero.secondaryButton.href}
              class="rounded-full border border-brand-slate/20 px-7 py-3 text-sm font-semibold text-brand-slate transition hover:border-brand-slate/40"
            >
              {hero.secondaryButton.text}
            </a>
          )}
        </div>
      </div>

      <div class="relative hidden h-80 lg:block" aria-hidden="true">
        <IconCluster anchorLogo="pratt" />
      </div>
    </div>
  </section>

  <BlockRenderer blocks={blocks} />
</BaseLayout>
