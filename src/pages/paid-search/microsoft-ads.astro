---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Icon from '../../components/Icon.astro';
import PlatformBadge from '../../components/PlatformBadge.astro';
import { cornerSearch } from '../../components/IconCluster.astro';

const reasons = [
  { title: 'Lower cost per click', description: 'Less competition typically means more efficient acquisition cost than Google alone.', icon: 'chart', color: 'green' },
  { title: 'Import & improve', description: 'We import your Google Ads structure and refine it for Microsoft’s audience and auction dynamics.', icon: 'layers', color: 'orange' },
  { title: 'Incremental reach', description: 'Reach the share of desktop and B2B searchers that Google Ads doesn’t cover.', icon: 'compass', color: 'green' },
  { title: 'Audience Network', description: 'Native and display placements across the Microsoft ecosystem, including LinkedIn profile targeting.', platform: 'linkedin', color: 'orange' },
] as const;

const borderColors = {
  green: 'border-brand-green',
  orange: 'border-brand-orange',
} as const;

const badgeColors = {
  green: 'bg-brand-green/10 text-brand-green-dark',
  orange: 'bg-brand-orange/10 text-brand-orange-dark',
} as const;
---

<BaseLayout
  title="Microsoft Ads Management"
  description="Microsoft Ads (Bing) management for brands who want incremental reach and lower cost-per-click alongside their Google Ads activity."
>
  <PageHero
    eyebrow="Paid Search / Microsoft Ads"
    title="Microsoft Ads Management: Reach the Audience Google Ads Misses"
    description="Microsoft Ads is often overlooked, but it's a genuine incremental channel, usually at a lower cost per click, with unique B2B targeting through LinkedIn profile data."
    platform="bing"
    cluster={cornerSearch}
    anchorLogo="bing"
  />

  <section class="bg-brand-slate">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="grid gap-6 sm:grid-cols-2">
        {reasons.map((item) => (
          <div class={`rounded-2xl border-2 bg-white p-6 ${borderColors[item.color]}`}>
            <div class={`flex h-12 w-12 items-center justify-center rounded-xl ${badgeColors[item.color]}`}>
              {'platform' in item ? (
                <PlatformBadge platform={item.platform} class="h-6 w-6" />
              ) : (
                <Icon name={item.icon} class="h-6 w-6" />
              )}
            </div>
            <h3 class="mt-4 font-semibold text-brand-slate">{item.title}</h3>
            <p class="mt-2 text-sm text-brand-slate-light">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner title="Not running Microsoft Ads yet?" description="Find out what incremental reach could look like for your account." />
</BaseLayout>
