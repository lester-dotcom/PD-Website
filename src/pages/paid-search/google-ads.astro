---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';

const capabilities = [
  { title: 'Search', description: 'Keyword-led campaigns matched to real commercial intent.' },
  { title: 'Shopping & Performance Max', description: 'Feed optimisation and structure that gives you visibility into what PMax is actually doing.' },
  { title: 'YouTube', description: 'Video campaigns for awareness and remarketing that tie back to conversion data.' },
  { title: 'Conversion tracking', description: 'Server-side and enhanced conversions set up properly, not left on platform defaults.' },
];
---

<BaseLayout
  title="Google Ads Management"
  description="Google Ads management covering Search, Shopping, Performance Max and YouTube — built on accurate conversion tracking and managed by a specialist."
>
  <PageHero
    eyebrow="Paid Search / Google Ads"
    title="Google Ads management with a specialist on the account"
    description="From Search and Shopping through to Performance Max and YouTube, we manage Google Ads accounts around your real sales data — not the recommendations tab."
  />

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-8 sm:grid-cols-2">
      {capabilities.map((item) => (
        <div class="rounded-2xl border border-gray-100 p-6">
          <h3 class="font-semibold text-brand-slate">{item.title}</h3>
          <p class="mt-2 text-sm text-brand-slate-light">{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <CtaBanner title="Want a second opinion on your Google Ads account?" />
</BaseLayout>
