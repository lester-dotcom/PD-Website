---
import { getImage } from 'astro:assets';
import { iconPaths, type IconName } from '../lib/icon-paths';
import googleIcon from '../assets/logos/icon/google.png';
import microsoftIcon from '../assets/logos/icon/microsoft.png';
import metaIcon from '../assets/logos/icon/meta.png';
import linkedinIcon from '../assets/logos/icon/linkedin.png';
import pinterestIcon from '../assets/logos/icon/pinterest.png';

export type AnchorLogo = 'google' | 'bing' | 'facebook' | 'linkedin' | 'pinterest' | 'pratt';

export interface CircleSpec {
  cx: number;
  cy: number;
  r: number;
  variant: 'fill-green' | 'fill-orange' | 'fill-slate' | 'outline-green' | 'outline-orange';
  icon?: IconName;
  letter?: string;
  isAnchor?: boolean;
}

interface Props {
  class?: string;
  viewBox?: string;
  circles?: CircleSpec[];
  anchorLogo?: AnchorLogo;
}

// Scattered circle-badge composition inspired by Pratt Digital's own office wall graphic
// (SMD_PD09_Wall-Graphics_AW.pdf). Only icons/letters that actually appear in that artwork
// are used here: hashtag, search, eye, location pin, thumbs up, gear, megaphone, YouTube
// play, forward arrow, Instagram camera, target, heart, and the Google/Bing/Facebook/
// Amazon/LinkedIn/Pinterest letter marks. The big anchor circle (blank in the source art,
// where the physical wall graphic has the Pratt Digital logo) shows a page-relevant platform
// icon or the Pratt favicon mark instead, via the anchorLogo prop.
export const heroCluster: CircleSpec[] = [
  { cx: 30, cy: 310, r: 22, variant: 'outline-orange', icon: 'hashtag' },
  { cx: 85, cy: 260, r: 28, variant: 'outline-green', icon: 'search' },
  { cx: 140, cy: 225, r: 19, variant: 'fill-slate', letter: 'b' },
  { cx: 185, cy: 255, r: 21, variant: 'outline-green', icon: 'target' },
  { cx: 100, cy: 195, r: 6, variant: 'fill-orange' },
  { cx: 235, cy: 205, r: 32, variant: 'fill-orange', icon: 'megaphone' },
  { cx: 283, cy: 155, r: 17, variant: 'fill-slate', letter: 'in' },
  { cx: 315, cy: 200, r: 23, variant: 'outline-green', icon: 'heart' },
  { cx: 340, cy: 135, r: 7, variant: 'fill-green' },
  { cx: 365, cy: 210, r: 19, variant: 'fill-slate', icon: 'instagram' },
  { cx: 395, cy: 170, r: 25, variant: 'outline-orange', icon: 'arrow-forward' },
  { cx: 420, cy: 115, r: 18, variant: 'fill-green', icon: 'eye' },
  { cx: 445, cy: 150, r: 13, variant: 'fill-orange', letter: 'G' },
  { cx: 410, cy: 55, r: 55, variant: 'fill-green', isAnchor: true },
  { cx: 55, cy: 345, r: 4, variant: 'fill-slate' },
  { cx: 200, cy: 330, r: 5, variant: 'fill-green' },
  { cx: 380, cy: 270, r: 4, variant: 'fill-orange' },
  { cx: 460, cy: 210, r: 5, variant: 'fill-slate' },
];

// Corner-accent variants for PageHero: different pages get different mixes, all still
// drawn from the same confirmed wall-graphic set, for the "mix it up" variety Lester asked for.
export const cornerSearch: CircleSpec[] = [
  { cx: 115, cy: 45, r: 42, variant: 'fill-green', isAnchor: true },
  { cx: 45, cy: 30, r: 18, variant: 'fill-slate', letter: 'b' },
  { cx: 40, cy: 90, r: 22, variant: 'outline-green', icon: 'search' },
  { cx: 120, cy: 105, r: 16, variant: 'outline-orange', icon: 'target' },
  { cx: 145, cy: 100, r: 5, variant: 'fill-orange' },
  { cx: 15, cy: 55, r: 4, variant: 'fill-slate' },
];

export const cornerSocial: CircleSpec[] = [
  { cx: 115, cy: 45, r: 42, variant: 'fill-orange', isAnchor: true },
  { cx: 45, cy: 30, r: 17, variant: 'fill-slate', letter: 'f' },
  { cx: 40, cy: 90, r: 21, variant: 'outline-orange', icon: 'heart' },
  { cx: 122, cy: 105, r: 16, variant: 'fill-slate', icon: 'instagram' },
  { cx: 15, cy: 55, r: 5, variant: 'fill-green' },
  { cx: 150, cy: 20, r: 4, variant: 'fill-orange' },
];

export const cornerAgency: CircleSpec[] = [
  { cx: 115, cy: 45, r: 42, variant: 'fill-green', isAnchor: true },
  { cx: 45, cy: 28, r: 17, variant: 'fill-slate', letter: 'in' },
  { cx: 40, cy: 90, r: 21, variant: 'outline-green', icon: 'thumbsup' },
  { cx: 122, cy: 105, r: 16, variant: 'outline-orange', icon: 'gear' },
  { cx: 15, cy: 55, r: 5, variant: 'fill-orange' },
  { cx: 150, cy: 20, r: 4, variant: 'fill-green' },
];

export const cornerContent: CircleSpec[] = [
  { cx: 115, cy: 45, r: 42, variant: 'fill-orange', isAnchor: true },
  { cx: 45, cy: 30, r: 18, variant: 'fill-slate', letter: 'P' },
  { cx: 40, cy: 90, r: 22, variant: 'outline-orange', icon: 'hashtag' },
  { cx: 122, cy: 105, r: 16, variant: 'fill-slate', icon: 'youtube' },
  { cx: 15, cy: 55, r: 4, variant: 'fill-green' },
  { cx: 150, cy: 20, r: 5, variant: 'fill-orange' },
];

export const cornerGeneral: CircleSpec[] = [
  { cx: 115, cy: 45, r: 42, variant: 'fill-green', isAnchor: true },
  { cx: 45, cy: 30, r: 17, variant: 'fill-slate', letter: 'a' },
  { cx: 40, cy: 90, r: 21, variant: 'outline-green', icon: 'eye' },
  { cx: 122, cy: 105, r: 16, variant: 'outline-orange', icon: 'arrow-forward' },
  { cx: 15, cy: 55, r: 5, variant: 'fill-orange' },
  { cx: 150, cy: 20, r: 4, variant: 'fill-slate' },
];

export const cornerClusters = [cornerSearch, cornerSocial, cornerAgency, cornerContent, cornerGeneral];

// Kept for back-compat with earlier callers.
export const cornerCluster = cornerGeneral;

const { class: className = 'h-full w-full', viewBox = '0 0 480 360', circles = heroCluster, anchorLogo } =
  Astro.props;

const fill = {
  'fill-green': 'var(--color-brand-green)',
  'fill-orange': 'var(--color-brand-orange)',
  'fill-slate': 'var(--color-brand-slate)',
  'outline-green': 'none',
  'outline-orange': 'none',
} as const;

const strokeColor = {
  'fill-green': 'none',
  'fill-orange': 'none',
  'fill-slate': 'none',
  'outline-green': 'var(--color-brand-green)',
  'outline-orange': 'var(--color-brand-orange)',
} as const;

const glyphColor = {
  'fill-green': 'white',
  'fill-orange': 'white',
  'fill-slate': 'white',
  'outline-green': 'var(--color-brand-green)',
  'outline-orange': 'var(--color-brand-orange)',
} as const;

const anchorBorder = {
  'fill-green': 'var(--color-brand-green)',
  'fill-orange': 'var(--color-brand-orange)',
  'fill-slate': 'var(--color-brand-slate)',
  'outline-green': 'var(--color-brand-green)',
  'outline-orange': 'var(--color-brand-orange)',
} as const;

let anchorImageHref: string | null = null;
if (anchorLogo) {
  const sources = {
    google: googleIcon,
    bing: microsoftIcon,
    facebook: metaIcon,
    linkedin: linkedinIcon,
    pinterest: pinterestIcon,
  } as const;

  if (anchorLogo === 'pratt') {
    anchorImageHref = '/favicon-512.png';
  } else {
    const optimized = await getImage({ src: sources[anchorLogo], width: 200 });
    anchorImageHref = optimized.src;
  }
}
---

<svg viewBox={viewBox} class={className} aria-hidden="true">
  {circles.map((c) => {
    const isOutline = c.variant.startsWith('outline');
    const iconSize = c.r * 1.15;
    const showAnchorLogo = c.isAnchor && anchorImageHref;
    const logoSize = c.r * 1.15;
    return (
      <g>
        <circle
          cx={c.cx}
          cy={c.cy}
          r={c.r}
          fill={showAnchorLogo ? 'white' : fill[c.variant]}
          stroke={showAnchorLogo ? anchorBorder[c.variant] : strokeColor[c.variant]}
          stroke-width={showAnchorLogo ? Math.max(2, c.r * 0.06) : isOutline ? Math.max(1.5, c.r * 0.09) : 0}
        />
        {showAnchorLogo && (
          <image
            href={anchorImageHref}
            x={c.cx - logoSize / 2}
            y={c.cy - logoSize / 2}
            width={logoSize}
            height={logoSize}
            preserveAspectRatio="xMidYMid meet"
          />
        )}
        {!showAnchorLogo && c.icon && (
          <g transform={`translate(${c.cx - iconSize / 2}, ${c.cy - iconSize / 2}) scale(${iconSize / 24})`}>
            <path
              d={iconPaths[c.icon]}
              fill="none"
              stroke={glyphColor[c.variant]}
              stroke-width="1.9"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </g>
        )}
        {!showAnchorLogo && c.letter && (
          <text
            x={c.cx}
            y={c.cy}
            text-anchor="middle"
            dominant-baseline="central"
            font-family="Roboto, Arial, sans-serif"
            font-weight="700"
            font-size={c.r * (c.letter.length > 1 ? 0.75 : 1)}
            fill={glyphColor[c.variant]}
          >
            {c.letter}
          </text>
        )}
      </g>
    );
  })}
</svg>
