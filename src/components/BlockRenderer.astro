---
import Icon from './Icon.astro';
import CtaBanner from './CtaBanner.astro';
import type { IconName } from '../lib/icon-paths';

interface FeatureGridBlock {
  type: 'featureGrid';
  items: { title: string; description: string; icon: IconName; color: 'green' | 'orange' }[];
}
interface CtaBlockType {
  type: 'cta';
  title: string;
  description: string;
}
interface TextBlockType {
  type: 'text';
  heading?: string;
  body: string;
}

type Block = FeatureGridBlock | CtaBlockType | TextBlockType;

interface Props {
  blocks: Block[];
}

const { blocks } = Astro.props;

const borderColors = { green: 'border-brand-green', orange: 'border-brand-orange' } as const;
const badgeColors = {
  green: 'bg-brand-green/10 text-brand-green-dark',
  orange: 'bg-brand-orange/10 text-brand-orange-dark',
} as const;
---

{blocks.map((block) => {
  if (block.type === 'featureGrid') {
    return (
      <section class="bg-brand-slate">
        <div class="mx-auto max-w-6xl px-6 py-20">
          <div class="grid gap-6 sm:grid-cols-2">
            {block.items.map((item) => (
              <div class={`rounded-2xl border-2 bg-white p-6 ${borderColors[item.color]}`}>
                <div class={`flex h-12 w-12 items-center justify-center rounded-xl ${badgeColors[item.color]}`}>
                  <Icon name={item.icon} class="h-6 w-6" />
                </div>
                <h3 class="mt-4 font-semibold text-brand-slate">{item.title}</h3>
                <p class="mt-2 text-sm text-brand-slate-light">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  }
  if (block.type === 'cta') {
    return <CtaBanner title={block.title} description={block.description} />;
  }
  if (block.type === 'text') {
    return (
      <section class="border-t border-gray-100 bg-gray-50">
        <div class="mx-auto max-w-3xl px-6 py-16 text-brand-slate-light">
          {block.heading && <h2 class="text-xl font-semibold text-brand-slate">{block.heading}</h2>}
          <p class="mt-4 whitespace-pre-line">{block.body}</p>
        </div>
      </section>
    );
  }
  return null;
})}
