---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import IconBadge from './IconBadge.astro';
import PlatformBadge from './PlatformBadge.astro';
import PlatformLogo from './PlatformLogo.astro';
import CtaBanner from './CtaBanner.astro';
import ameliaPhoto from '../assets/team/amelia.jpg';
import lesterPhoto from '../assets/team/lester.jpg';
import type { IconName } from '../lib/icon-paths';
import type { PlatformName } from './PlatformBadge.astro';

type CardColor = 'green' | 'orange';
type Background = 'slate' | 'white' | 'gray';

interface GridItem {
  title: string;
  description: string;
  icon?: IconName;
  platform?: PlatformName;
  logoStyle?: 'badge' | 'full';
  href?: string;
  color: CardColor;
}

interface FeatureGridBlock {
  type: 'featureGrid';
  eyebrow?: string;
  heading?: string;
  columns: 2 | 3;
  cardStyle: 'bordered' | 'plain';
  background: Background;
  items: GridItem[];
}
interface CtaBlockType {
  type: 'cta';
  title: string;
  description: string;
}
interface TextBlockType {
  type: 'text';
  heading?: string;
  body: string;
  background: Background;
  icon?: IconName;
}
interface ChannelsListBlock {
  type: 'channelsList';
  eyebrow: string;
  heading: string;
  intro: string;
  items: { title: string; description: string; icon?: IconName; platform?: PlatformName }[];
}
interface TeamBiosBlock {
  type: 'teamBios';
  eyebrow: string;
  heading: string;
  members: { name: string; role: string; photoKey: 'amelia' | 'lester'; bio: string }[];
}
interface ProcessStepsBlock {
  type: 'processSteps';
  eyebrow: string;
  heading: string;
  note: string;
  steps: { title: string; description: string }[];
}

type Block = FeatureGridBlock | CtaBlockType | TextBlockType | ChannelsListBlock | TeamBiosBlock | ProcessStepsBlock;

interface Props {
  blocks: Block[];
}

const { blocks } = Astro.props;

const borderColors = { green: 'border-brand-green', orange: 'border-brand-orange' } as const;
const badgeColors = {
  green: 'bg-brand-green/10 text-brand-green-dark',
  orange: 'bg-brand-orange/10 text-brand-orange-dark',
} as const;
const teamPhotos = { amelia: ameliaPhoto, lester: lesterPhoto } as const;

// Lightweight *word* -> <em> markdown for the italic accent used across headings.
function emphasisParts(text: string) {
  return text.split(/\*(.+?)\*/).map((part, i) => ({ text: part, italic: i % 2 === 1 }));
}

const gridColClass = (columns: 2 | 3, cardStyle: 'bordered' | 'plain') => {
  if (cardStyle === 'plain') return columns === 3 ? 'sm:grid-cols-3' : 'sm:grid-cols-2';
  return columns === 3 ? 'sm:grid-cols-2 lg:grid-cols-3' : 'sm:grid-cols-2';
};

const sectionBg = (background: Background) => {
  if (background === 'slate') return 'bg-brand-slate';
  if (background === 'gray') return 'border-t border-gray-100 bg-gray-50';
  return 'border-t border-gray-100 bg-white';
};
---

{blocks.map((block) => {
  if (block.type === 'featureGrid') {
    return (
      <section class={sectionBg(block.background)}>
        <div class="mx-auto max-w-6xl px-6 py-20">
          {(block.eyebrow || block.heading) && (
            <div class="mb-10">
              {block.eyebrow && (
                <div class="flex items-center gap-3">
                  <span class={`h-px w-8 ${block.background === 'slate' ? 'bg-brand-green' : 'bg-brand-orange'}`}></span>
                  <p class={`text-sm font-semibold uppercase tracking-wide ${block.background === 'slate' ? 'text-white/60' : 'text-brand-slate-light'}`}>
                    {block.eyebrow}
                  </p>
                </div>
              )}
              {block.heading && (
                <h2 class={`mt-3 text-3xl font-bold sm:text-4xl ${block.background === 'slate' ? 'text-white' : 'text-brand-slate'}`}>
                  {emphasisParts(block.heading).map((p) =>
                    p.italic ? <span class="font-light italic text-brand-green">{p.text}</span> : p.text
                  )}
                </h2>
              )}
            </div>
          )}

          <div class={`grid gap-6 ${gridColClass(block.columns, block.cardStyle)}`}>
            {block.items.map((item) => {
              const Wrapper = item.href ? 'a' : 'div';
              const wrapperProps = item.href ? { href: item.href } : {};
              const cardClasses =
                block.cardStyle === 'bordered'
                  ? `rounded-2xl border-2 bg-white ${item.logoStyle === 'full' ? 'p-8' : 'p-6'} ${borderColors[item.color]} ${item.href ? 'group transition hover:-translate-y-1 hover:shadow-lg' : ''}`
                  : `${item.href ? 'group' : ''}`;
              return (
                <Wrapper {...wrapperProps} class={cardClasses}>
                  {item.logoStyle === 'full' && item.platform ? (
                    <PlatformLogo platform={item.platform} class="h-8 w-auto" />
                  ) : item.platform ? (
                    <div class={`flex h-12 w-12 items-center justify-center rounded-xl ${badgeColors[item.color]}`}>
                      <PlatformBadge platform={item.platform} class="h-6 w-6" />
                    </div>
                  ) : (
                    <IconBadge icon={item.icon ?? 'target'} color={item.color} />
                  )}
                  <h3 class="mt-4 font-semibold text-brand-slate">{item.title}</h3>
                  <p class="mt-2 text-sm text-brand-slate-light">{item.description}</p>
                  {item.href && (
                    <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-green-dark opacity-0 transition group-hover:opacity-100">
                      Learn more →
                    </span>
                  )}
                </Wrapper>
              );
            })}
          </div>
        </div>
      </section>
    );
  }

  if (block.type === 'cta') {
    return <CtaBanner title={block.title} description={block.description} />;
  }

  if (block.type === 'text') {
    const isSlate = block.background === 'slate';
    return (
      <section class={sectionBg(block.background)}>
        <div class={`mx-auto max-w-3xl px-6 py-16 ${isSlate ? 'border-t border-white/10' : ''}`}>
          {block.icon && (
            <div class={`flex h-12 w-12 items-center justify-center rounded-xl ${isSlate ? 'bg-white/10 text-brand-green' : 'bg-brand-green/10 text-brand-green-dark'}`}>
              <Icon name={block.icon} class="h-6 w-6" />
            </div>
          )}
          {block.heading && (
            <h2 class={`mt-4 text-xl font-semibold ${isSlate ? 'text-white' : 'text-brand-slate'} ${!block.icon ? 'text-2xl sm:text-3xl' : ''}`}>
              {block.heading}
            </h2>
          )}
          <div class={`mt-4 space-y-4 ${isSlate ? 'text-white/60' : 'text-brand-slate-light'}`}>
            {block.body.split(/\n\s*\n/).map((para) => <p>{para}</p>)}
          </div>
        </div>
      </section>
    );
  }

  if (block.type === 'channelsList') {
    return (
      <section class="bg-white">
        <div class="mx-auto grid max-w-6xl gap-12 px-6 py-20 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)] lg:items-start">
          <div>
            <div class="flex items-center gap-3">
              <span class="h-px w-8 bg-brand-orange"></span>
              <p class="text-sm font-semibold uppercase tracking-wide text-brand-slate-light">{block.eyebrow}</p>
            </div>
            <h2 class="mt-3 text-3xl font-bold text-brand-slate sm:text-4xl">
              {emphasisParts(block.heading).map((p) => (p.italic ? <span class="font-light italic">{p.text}</span> : p.text))}
            </h2>
            <p class="mt-5 text-brand-slate-light">{block.intro}</p>
          </div>

          <div class="grid divide-y divide-gray-100 overflow-hidden rounded-2xl border border-gray-100 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
            {block.items.map((item) => (
              <div class="flex gap-3 p-6">
                {item.platform ? (
                  <PlatformBadge platform={item.platform} class="mt-0.5 h-5 w-5 shrink-0 text-brand-green-dark" />
                ) : (
                  <Icon name={item.icon ?? 'sparkles'} class="mt-0.5 h-5 w-5 shrink-0 text-brand-green-dark" />
                )}
                <div>
                  <h3 class="font-semibold text-brand-slate">{item.title}</h3>
                  <p class="mt-1 text-sm text-brand-slate-light">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (block.type === 'teamBios') {
    return (
      <section class="border-t border-gray-100 bg-white">
        <div class="mx-auto max-w-6xl px-6 py-20">
          <div class="flex items-center gap-3">
            <span class="h-px w-8 bg-brand-green"></span>
            <p class="text-sm font-semibold uppercase tracking-wide text-brand-slate-light">{block.eyebrow}</p>
          </div>
          <h2 class="mt-3 text-3xl font-bold text-brand-slate sm:text-4xl">
            {emphasisParts(block.heading).map((p) => (p.italic ? <span class="font-light italic">{p.text}</span> : p.text))}
          </h2>

          <div class="mt-12 grid gap-12 sm:grid-cols-2">
            {block.members.map((person) => (
              <div class="flex gap-5">
                <Image
                  src={teamPhotos[person.photoKey]}
                  alt={`${person.name}, ${person.role} at Pratt Digital`}
                  width={128}
                  height={128}
                  loading="lazy"
                  decoding="async"
                  class="h-32 w-32 shrink-0 rounded-full object-cover"
                />
                <div>
                  <h3 class="font-semibold text-brand-slate">{person.name}</h3>
                  <p class="text-sm font-medium text-brand-green-dark">{person.role}</p>
                  <p class="mt-3 text-sm text-brand-slate-light">{person.bio}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (block.type === 'processSteps') {
    return (
      <section class="bg-brand-slate">
        <div class="mx-auto max-w-6xl px-6 py-20">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)] lg:items-end">
            <div>
              <div class="flex items-center gap-3">
                <span class="h-px w-8 bg-brand-green"></span>
                <p class="text-sm font-semibold uppercase tracking-wide text-white/60">{block.eyebrow}</p>
              </div>
              <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">
                {emphasisParts(block.heading).map((p) =>
                  p.italic ? <span class="font-light italic text-brand-green">{p.text}</span> : p.text
                )}
              </h2>
            </div>
            <p class="text-white/60">{block.note}</p>
          </div>

          <div class="mt-14 grid gap-10 sm:grid-cols-3 sm:divide-x sm:divide-white/10">
            {block.steps.map((step, i) => (
              <div class="sm:px-8 sm:first:pl-0">
                <p class="text-4xl font-bold text-brand-green">0{i + 1}</p>
                <h3 class="mt-4 font-semibold text-white">{step.title}</h3>
                <p class="mt-2 text-sm text-white/60">{step.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  }

  return null;
})}
