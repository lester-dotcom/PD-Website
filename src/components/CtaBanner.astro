---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Let's talk about your account",
  description = "Get a no-obligation review of your paid search and social performance from a specialist, not an account manager reading a script.",
} = Astro.props;
---

<section class="bg-brand-slate">
  <div class="mx-auto max-w-4xl px-6 py-16 text-center">
    <h2 class="text-2xl font-bold text-white sm:text-3xl">{title}</h2>
    <p class="mx-auto mt-4 max-w-xl text-white/70">{description}</p>
    <a
      href="/contact-us"
      class="mt-8 inline-block rounded-full bg-brand-green px-7 py-3 text-sm font-semibold text-brand-slate transition hover:bg-brand-green-dark"
    >
      Get in Touch
    </a>
  </div>
</section>
