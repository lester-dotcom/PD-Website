---
import { Image } from 'astro:assets';
import { iconPaths } from '../lib/icon-paths';
import googleIcon from '../assets/logos/icon/google.png';
import microsoftIcon from '../assets/logos/icon/microsoft.png';
import metaIcon from '../assets/logos/icon/meta.png';
import linkedinIcon from '../assets/logos/icon/linkedin.png';
import pinterestIcon from '../assets/logos/icon/pinterest.png';

export type PlatformName = 'google' | 'bing' | 'facebook' | 'instagram' | 'linkedin' | 'pinterest' | 'youtube';

interface Props {
  platform: PlatformName;
  class?: string;
}

const { platform, class: className = 'h-6 w-6' } = Astro.props;

const images = {
  google: { src: googleIcon, alt: 'Google Ads' },
  bing: { src: microsoftIcon, alt: 'Microsoft Advertising' },
  facebook: { src: metaIcon, alt: 'Meta' },
  linkedin: { src: linkedinIcon, alt: 'LinkedIn' },
  pinterest: { src: pinterestIcon, alt: 'Pinterest' },
} as const;

const image = platform in images ? images[platform as keyof typeof images] : null;
---

{image ? (
  <Image
    src={image.src}
    alt={image.alt}
    width={image.src.width}
    height={image.src.height}
    class={`${className} object-contain`}
  />
) : (
  <svg
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    <path d={iconPaths[platform]} />
  </svg>
)}
