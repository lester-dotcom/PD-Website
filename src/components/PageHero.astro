---
import IconCluster, { cornerCluster } from './IconCluster.astro';
import PlatformBadge, { type PlatformName } from './PlatformBadge.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  platform?: PlatformName;
}

const { eyebrow, title, description, platform } = Astro.props;
---

<section class="relative overflow-hidden border-b border-gray-100 bg-gray-50">
  <div class="pointer-events-none absolute -right-6 -top-6 h-40 w-40 opacity-90 sm:h-52 sm:w-52">
    <IconCluster viewBox="0 0 160 100" circles={cornerCluster} />
  </div>

  <div class="relative mx-auto max-w-4xl px-6 py-16 text-center sm:py-20">
    {platform && (
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-slate text-white">
        <PlatformBadge platform={platform} class="h-7 w-7" />
      </div>
    )}
    {eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-wide text-brand-green-dark">{eyebrow}</p>
    )}
    <h1 class="mt-3 text-4xl font-bold text-brand-slate sm:text-5xl">{title}</h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-brand-slate-light">{description}</p>
  </div>
</section>
