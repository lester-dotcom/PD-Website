---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="relative overflow-hidden border-b border-gray-100 bg-gray-50">
  <svg
    class="pointer-events-none absolute inset-0 h-full w-full opacity-40"
    aria-hidden="true"
  >
    <defs>
      <pattern id="hero-dots" width="24" height="24" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1.4" fill="var(--color-brand-slate-light)" opacity="0.35" />
      </pattern>
      <linearGradient id="hero-fade" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="white" stop-opacity="0" />
        <stop offset="100%" stop-color="var(--color-brand-slate-light)" stop-opacity="0.15" />
      </linearGradient>
    </defs>
    <rect width="100%" height="100%" fill="url(#hero-dots)" />
  </svg>
  <div class="absolute -right-16 -top-16 h-56 w-56 rounded-full bg-brand-green opacity-10" aria-hidden="true"></div>
  <div class="absolute -bottom-20 -left-10 h-48 w-48 rounded-full bg-brand-orange opacity-10" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-4xl px-6 py-16 text-center sm:py-20">
    {eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-wide text-brand-green-dark">{eyebrow}</p>
    )}
    <h1 class="mt-3 text-4xl font-bold text-brand-slate sm:text-5xl">{title}</h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-brand-slate-light">{description}</p>
  </div>
</section>
