---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="border-b border-gray-100 bg-gray-50">
  <div class="mx-auto max-w-4xl px-6 py-16 text-center sm:py-20">
    {eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-wide text-brand-green-dark">{eyebrow}</p>
    )}
    <h1 class="mt-3 text-4xl font-bold text-brand-slate sm:text-5xl">{title}</h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-brand-slate-light">{description}</p>
  </div>
</section>
